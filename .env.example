# ===================== Deployment (used by deploy.sh) =====================
# The single host that serves everything (UI + API on one origin). The app runs in Docker
# on 127.0.0.1:8080; the HOST nginx terminates TLS and reverse-proxies to it. Use the bare
# hostname — no http(s)://, no trailing slash.
#   https://${DOMAIN}/        -> designer UI  (also the API URL to enter in the gear modal)
#   https://${DOMAIN}/v1/*    -> render API   (any n8n instance calls this server-to-server
#                                              with X-API-Key; same origin, so no CORS)
DOMAIN=your-domain.com
# Email for Let's Encrypt (expiry notices + ToS). Required unless you pass --no-tls.
LETSENCRYPT_EMAIL=you@example.com

# ===================== Render API =====================
API_SECRET_TOKEN=__CHANGE_ME__              # openssl rand -base64 36   (clients send this as X-API-Key)
# Comma-separated hostnames allowed as REMOTE (http/s) image sources. EMPTY = remote
# image fetching disabled (most secure default). Uploaded images are inline data: URIs
# and are NOT affected by this — they always work, gated only by MAX_IMAGE_BYTES.
ALLOWED_IMAGE_HOSTS=
RENDER_CONCURRENCY=3
RENDER_QUEUE_MAX=50
RENDER_TIMEOUT_MS=15000
IMAGE_FETCH_TIMEOUT_MS=5000
MAX_IMAGE_BYTES=5242880
# Must hold a base64-inlined image (≈1.34× MAX_IMAGE_BYTES) plus the surrounding JSON,
# since uploaded images are embedded as data: URIs in render/template bodies. Keep the
# nginx client_max_body_size for the API server >= this value.
BODY_LIMIT=12mb
RATE_WINDOW_MS=60000
RATE_MAX=120
# Reverse-proxy hops in front of the app, for correct client IP / rate limiting.
# Prod (host nginx + Docker nginx) = 2. Local dev (single nginx) = 1.
TRUST_PROXY=2
LOG_LEVEL=info
# Browser CORS allow-list (comma-separated origins). UNSET = no CORS headers = locked
# down (correct for production, where nginx adds the explicit app-origin header).
# Use '*' for LOCAL DEV ONLY — never ship '*' to production.
# CORS_ALLOWED_ORIGINS=https://app.your-domain.com
# Chromium sandbox: the container is hardened (non-root, cap_drop ALL, read-only, no-new-privileges),
# so Chromium's own sandbox is disabled. Keep true unless you supply a seccomp profile (see §13).
CHROME_NO_SANDBOX=true

# ===================== MinIO =====================
MINIO_ROOT_USER=__CHANGE_ME__
MINIO_ROOT_PASSWORD=__CHANGE_ME__           # openssl rand -base64 24
MINIO_BUCKET_NAME=generated-banners
# Scoped application account (auto-created by the minio-init service). The render API
# uses THIS account (not root) to store/serve uploaded source images.
MINIO_APP_USER=banner-app
MINIO_APP_PASSWORD=__CHANGE_ME__            # openssl rand -base64 24
# Set MINIO_ENDPOINT to enable uploads; unset = uploads disabled (designer falls back to
# inline data: URIs). Endpoint is the internal service name; the S3 port is never exposed.
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
# Object-name prefix for uploaded source images within the bucket.
MINIO_UPLOADS_PREFIX=uploads/

# n8n is NOT part of this stack — it runs separately and calls https://api.${DOMAIN}
# with the API_SECRET_TOKEN above as X-API-Key. No n8n config belongs in this file.
